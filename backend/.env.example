# Copy to backend/.env. Everything is optional — the API boots without any of it
# (in-memory store, Weave off) so you can run GET /health on day one.

# --- W&B / Weave (already provisioned in the repo-root .env) ---
WANDB_API_KEY=
WANDB_ENTITY=yamanbicer-mindra
WANDB_PROJECT=company-brain-harness

# --- Models ---
ANTHROPIC_API_KEY=                 # Claude Agent SDK (request via hackathon API form)
WANDB_INFERENCE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- Agent tools / web research (all degrade to a deterministic mock with no key) ---
# Firecrawl powers web_search/fetch_url and the market_research/competitor_scan/
# product_research wrappers (search + scrape, so it covers Crunchbase/Product Hunt
# without per-site APIs). Tavily is an alternative. Empty => rich offline mock.
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
WEB_SEARCH_PROVIDER=auto           # auto | firecrawl | tavily | mock
TOOL_MAX_CALLS=3                   # ReAct loop cap per agent per turn

# --- Live MCP (optional). Point at mcp_servers.json to expose external MCP tools
# (e.g. the W&B/Weave MCP as `weave_query`). Empty => no MCP tools, council still runs.
MCP_CONFIG_PATH=                   # e.g. mcp_servers.json

# --- Supabase (Postgres + Auth). Leave blank to use the in-memory store. ---
# Setting SUPABASE_URL also enables auth: user tokens are verified against the
# project's published JWKS (ES256). No JWT secret needed — verification is keyed
# off the URL. With auth enabled, every request needs a valid Bearer token.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Only for `python -m backend.db.migrate` (applies the schema DDL). Get it from
# Supabase → Settings → Database → Connection string → URI (includes the DB
# password). Not used at runtime.
SUPABASE_DB_URL=

# --- CORS: where the Next.js frontend runs ---
FRONTEND_ORIGIN=http://localhost:3000
