# Copy this file to .env and fill in your values:  cp .env.example .env

# Required. Get your key at https://wandb.ai/authorize
WANDB_API_KEY=

# Your W&B username or team slug (the "entity"). It's the path segment after
# wandb.ai/ in your dashboard URL. Optional but recommended for usage tracking.
WANDB_ENTITY=

# Project name. Weave creates it automatically on first run.
WANDB_PROJECT=company-brain-harness

# Model served by W&B Inference. See https://docs.wandb.ai/inference for the list.
WANDB_INFERENCE_MODEL=meta-llama/Llama-3.1-8B-Instruct
