# Copy to frontend/.env.local
# Use 127.0.0.1 (literal IPv4), not "localhost": uvicorn binds IPv4-only by
# default, and a browser resolving localhost to IPv6 ::1 gets a refused
# connection ("TypeError: Failed to fetch").
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Supabase Auth (leave blank to run against the dev/in-memory backend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
